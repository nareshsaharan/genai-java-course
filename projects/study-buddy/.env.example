# Copy this file to .env and fill in real values. Never commit the real .env file.
#
# None of the API keys below are read by the running app — every session
# configures its own keys from the Settings tab in the browser instead (see
# RuntimeSecretsService). ANTHROPIC_API_KEY/OPENAI_API_KEY/etc. only exist so
# ClaudeProperties/AudioProperties can bind their non-key fields (model name,
# timeouts) without Spring complaining about a missing property; leaving them
# blank is fine and expected. Without any key configured in Settings, every
# AI-backed feature runs in Mock Mode (canned responses) instead of failing.

# --- Database (used by docker-compose and by application.yml) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=study_buddy
DB_USERNAME=study_buddy
DB_PASSWORD=study_buddy

# --- Claude (Anthropic) — one of four chat providers, selectable in Settings ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Leave unset unless your model supports it — some Claude models reject
# the request if temperature is sent at all.
ANTHROPIC_TEMPERATURE=
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TIMEOUT_SECONDS=30

# --- Groq — free-tier chat provider, OpenAI-compatible API ---
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=30

# --- OpenRouter — free-tier chat provider, OpenAI-compatible API ---
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_TIMEOUT_SECONDS=30

# --- Gemini (Google AI) — free-tier chat AND/OR embeddings, one key does both ---
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_TIMEOUT_SECONDS=30

# --- RAG chunking / retrieval ---
RAG_CHUNK_SIZE_TOKENS=400
RAG_CHUNK_OVERLAP_TOKENS=40
RAG_MAX_RESULTS=5
RAG_MIN_SCORE=0.4

# --- Weak-topic classification / recommendation ---
PROGRESS_MIN_ATTEMPTS=5
PROGRESS_WEAK_THRESHOLD=0.6
PROGRESS_RECENCY_WEIGHT=0.4
PROGRESS_SIMILARITY_TOLERANCE=0.05

# --- MCP server (only read when --spring.profiles.active=mcp) ---
# Required to enable the MCP endpoint at all; every /mcp request is rejected
# with 503 if this is blank, even under the "mcp" profile.
MCP_API_KEY=

# --- OpenAI — the default embedding provider, and always used for Whisper voice ---
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
AUDIO_MAX_FILE_SIZE_BYTES=10485760
AUDIO_MAX_DURATION_SECONDS=120
AUDIO_TIMEOUT_SECONDS=30
AUDIO_MAX_RETRIES=2
# Recordings are never written to disk unless this is explicitly "true".
AUDIO_PERSIST_RECORDINGS=false
AUDIO_RECORDINGS_DIRECTORY=./data/audio-recordings
# Leave blank to use the JVM's default temp directory.
AUDIO_TEMP_DIRECTORY=
