# Copy this file to .env and fill in real values. Never commit the real .env file.

# --- Database (used by docker-compose and by application.yml) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=study_buddy
DB_USERNAME=study_buddy
DB_PASSWORD=study_buddy

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Leave unset unless your model supports it — some Claude models reject
# the request if temperature is sent at all.
ANTHROPIC_TEMPERATURE=
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TIMEOUT_SECONDS=30

# --- RAG chunking / retrieval ---
RAG_CHUNK_SIZE_TOKENS=400
RAG_CHUNK_OVERLAP_TOKENS=40
RAG_MAX_RESULTS=5
RAG_MIN_SCORE=0.4

# --- Weak-topic classification / recommendation ---
PROGRESS_MIN_ATTEMPTS=5
PROGRESS_WEAK_THRESHOLD=0.6
PROGRESS_RECENCY_WEIGHT=0.4
PROGRESS_SIMILARITY_TOLERANCE=0.05

# --- MCP server (only read when --spring.profiles.active=mcp) ---
# Required to enable the MCP endpoint at all; every /mcp request is rejected
# with 503 if this is blank, even under the "mcp" profile.
MCP_API_KEY=

# --- OpenAI (embeddings + optional voice input) ---
# Required for the core RAG pipeline: document ingestion and retrieval both
# embed text via OpenAI's text-embedding-3-small (truncated to 384 dims) —
# without this key, /api/documents/upload, /api/tutor/chat, /api/flashcards,
# and /api/quizzes/generate all return 503. Also used for Whisper voice
# transcription (/api/audio/transcribe) if set; that endpoint alone stays
# optional/503-only, but the key itself is otherwise required.
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
AUDIO_MAX_FILE_SIZE_BYTES=10485760
AUDIO_MAX_DURATION_SECONDS=120
AUDIO_TIMEOUT_SECONDS=30
AUDIO_MAX_RETRIES=2
# Recordings are never written to disk unless this is explicitly "true".
AUDIO_PERSIST_RECORDINGS=false
AUDIO_RECORDINGS_DIRECTORY=./data/audio-recordings
# Leave blank to use the JVM's default temp directory.
AUDIO_TEMP_DIRECTORY=
